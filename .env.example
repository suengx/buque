# 一份 .env 通吃开发与生产。
# - make dev：直接读本文件（localhost 默认值）
# - docker-compose.*.yml：自动覆盖 DATABASE_URL / CORS / VITE 构建参数

# --- Docker 镜像源（腾讯云 ECS 默认已写在 compose；本地 Mac docker build 可留空）---
# DOCKER_REGISTRY_PREFIX=mirror.ccs.tencentyun.com/library/
# DOCKER_REGISTRY_PREFIX=

# --- 生产：IP 访问（未备案，docker-compose.ip.yml）---
# 与浏览器地址栏一致，如 http://43.1.1.1 或 http://43.1.1.1:8080
SITE_URL=
# 宿主机映射端口，默认 80；与 1Panel 冲突时改为 8080 并同步改 SITE_URL
# HTTP_PORT=8080

# --- 生产：域名 + HTTPS（已备案，docker-compose.prod.yml）---
DOMAIN=
ACME_EMAIL=

# --- 数据库（Compose 内 Postgres；生产 DATABASE_URL 由 compose 按下列变量拼装）---
POSTGRES_USER=buque
POSTGRES_PASSWORD=buque
POSTGRES_DB=buque
DATABASE_URL=postgresql+psycopg://buque:buque@localhost:5432/buque

# --- Backend ---
TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000

# --- ERP（只读账号，勿提交真实凭证）---
ERP_BASE_URL=
ERP_USERNAME=
ERP_PASSWORD=
# ERP_WEB_PREFIX=/amzv-web
ERP_SYNC_TIMEOUT_MS=240000
ERP_ORDERS_EXPORT_TIMEOUT_MS=360000

# --- LLM（监控助手，Anthropic 兼容网关）---
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
AGENT_MODEL=qwen3.5-flash
STREAM_MODE=true
AGENT_MAX_TURNS=8

# --- Auth ---
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
AUTH_REQUIRED=true
AUTH_PASSWORD_ENABLED=

# --- Frontend（仅 npm run dev；生产 build 由 compose 从 SITE_URL 或 DOMAIN 注入）---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_CLIENT_ID=
VITE_AUTH_PASSWORD_ENABLED=

# --- 可选：手动单次日批（docker compose exec -e BUQUE_USE_ERP=1 api buque-job）---
# BUQUE_USE_ERP=1
