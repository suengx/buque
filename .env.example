# 一份 .env 通吃开发与生产。
# - make dev：直接读本文件（localhost 默认值）
# - docker-compose.prod.yml：自动覆盖 DATABASE_URL / CORS / VITE 构建参数，无需改下面几项

# --- 生产部署额外填写（Compose 据此生成 HTTPS / 内网 DB 连接）---
DOMAIN=
ACME_EMAIL=

# --- 数据库（Compose 内 Postgres；生产 DATABASE_URL 由 compose 按下列变量拼装）---
POSTGRES_USER=buque
POSTGRES_PASSWORD=buque
POSTGRES_DB=buque
DATABASE_URL=postgresql+psycopg://buque:buque@localhost:5432/buque

# --- Backend ---
TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000

# --- ERP（只读账号，勿提交真实凭证）---
ERP_BASE_URL=
ERP_USERNAME=
ERP_PASSWORD=
# ERP_WEB_PREFIX=/amzv-web
ERP_SYNC_TIMEOUT_MS=240000
ERP_ORDERS_EXPORT_TIMEOUT_MS=360000

# --- LLM（监控助手，Anthropic 兼容网关）---
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
AGENT_MODEL=qwen3.5-flash
STREAM_MODE=true
AGENT_MAX_TURNS=8

# --- Auth ---
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
AUTH_REQUIRED=true
AUTH_PASSWORD_ENABLED=

# --- Frontend（仅 npm run dev 使用；生产镜像 build 时由 compose 从 DOMAIN / GOOGLE_CLIENT_ID 注入）---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_CLIENT_ID=
VITE_AUTH_PASSWORD_ENABLED=

# --- 可选：手动单次日批（docker compose exec -e BUQUE_USE_ERP=1 api buque-job）---
# BUQUE_USE_ERP=1
