# 一份 .env 通吃开发与生产。
# - make dev：直接读本文件（localhost 默认值）
# - ECS 模式 B：见下方「IP 访问」整段；勿设 BUQUE_IMAGE_REGISTRY / PLAYWRIGHT_* 镜像变量

# --- 镜像发布（模式 B 默认：下面两项留空或不要写）---
# BUQUE_IMAGE_REGISTRY=ghcr.io/<用户名>   # 仅模式 A（GHCR pull）时填写
# BUQUE_IMAGE_TAG=main

# --- 生产：IP 访问（docker-compose.ip.yml，ECS 模式 B 必填段）---
SITE_URL=http://<ECS公网IP>:8080
HTTP_PORT=8080
DOCKER_REGISTRY_PREFIX=mirror.ccs.tencentyun.com/library/
DEBIAN_APT_MIRROR=mirrors.tencent.com
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
# 模式 B 构建必须留空或删除以下两行（npmmirror 会导致 Playwright 构建失败）：
# PLAYWRIGHT_DOWNLOAD_HOST=
# PLAYWRIGHT_DOWNLOAD_BASE_URL=

# --- 生产：域名 + HTTPS（已备案，docker-compose.prod.yml）---
DOMAIN=
ACME_EMAIL=

# --- 数据库（POSTGRES_* 拼装连接串，密码可含特殊字符；Compose 内网时覆盖 POSTGRES_HOST=postgres）---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=buque
POSTGRES_PASSWORD=buque
POSTGRES_DB=buque

# --- Backend ---
TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000

# --- ERP（只读账号，勿提交真实凭证）---
ERP_BASE_URL=
ERP_USERNAME=
ERP_PASSWORD=
# ERP_WEB_PREFIX=/amzv-web
ERP_SYNC_TIMEOUT_MS=240000
ERP_ORDERS_EXPORT_TIMEOUT_MS=360000

# --- LLM（监控助手，Anthropic 兼容网关）---
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
AGENT_MODEL=qwen3.5-flash
STREAM_MODE=true
AGENT_MAX_TURNS=8

# --- Auth ---
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
AUTH_REQUIRED=true
AUTH_PASSWORD_ENABLED=

# --- Frontend（仅 npm run dev；生产 build 由 compose 从 SITE_URL 或 DOMAIN 注入）---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_CLIENT_ID=
VITE_AUTH_PASSWORD_ENABLED=

# --- 可选：手动单次日批（docker compose exec -e BUQUE_USE_ERP=1 api buque-job）---
# BUQUE_USE_ERP=1
